        _dragEndCbs[inID] = function(i)
            if dr and (i.UserInputType == _MB1 or i.UserInputType == _TC) then
                dr = false; dragInputType = nil
            end
        end
        _dragCbs[inID] = function(i)
            if dr and i.UserInputType == dragInputType then
                local newX = spX + (i.Position.X - dsX)
                local newY = spY + (i.Position.Y - dsY)
                local vps = CAM and CAM.ViewportSize or Vector2.new(1920,1080)
                newX = math.clamp(newX, 0, vps.X - WIN_W)
                newY = math.clamp(newY, 0, vps.Y - TOP_H)
