local function hideTooltip()
	TooltipManager._showing = false
	if TooltipManager._tip then
		TooltipManager._tip.Visible = false
	end
	if TooltipManager._delayTimer then
		cancelTimer(TooltipManager._delayTimer)
		TooltipManager._delayTimer = nil
	end
end
local function startTooltip(text, guiObject)
	if TooltipManager._active == guiObject then return end
	hideTooltip()
	TooltipManager._active = guiObject
	TooltipManager._delayTimer = taskDelay(0.5, function()
		local pos = guiObject.AbsolutePosition + Vector2.new(guiObject.AbsoluteSize.X, 0)
		showTooltip(text, pos)
		TooltipManager._delayTimer = nil
	end)
end
local function stopTooltip(guiObject)
	if TooltipManager._active == guiObject then
		hideTooltip()
		TooltipManager._active = nil
	end
end
