            W._flatSec = nil
            W._activeSection = nil
            W._kbWaiters = nil
            W._dropdowns = nil
            W._colorpickers = nil
            W._keybinds = nil
            sg:Destroy()
        end
        function W:SetVisible(v)
            if v == nil then sg.Enabled = not sg.Enabled else sg.Enabled = v == true end
            if not sg.Enabled then
                if W._dropdowns then for _, dd in ipairs(W._dropdowns) do if dd.Close then dd:Close() end end end
                if W._colorpickers then for _, cp in ipairs(W._colorpickers) do if cp.Close then cp:Close() end end end
                if W._keybinds then for _, kb in ipairs(W._keybinds) do if kb.CancelWait then kb:CancelWait() end end end
            end
        end
        function W:Hide() W:SetVisible(false) end
        function W:Show() W:SetVisible(true) end
        table.insert(W.C, cl.MouseButton1Click:Connect(function() W:Destroy() end))
        table.insert(W.C, sg.Destroying:Connect(function() W:Destroy() end))
        return W
    end
