local function _makeSeparator(parent)
	return cr("Frame",{Size=UDim2.new(1,0,0,1),BackgroundColor3=T.Sep,BorderSizePixel=0,Parent=parent})
end

local function _makeLabel(parent, tx)
	return cr("TextLabel",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Text=tx,TextColor3=T.Dim,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=parent})
end

local function _makeButton(parent, W, tx, cb, cnf)
	local b = cr("TextButton",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,Text="  "..tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,Parent=parent})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=b})
	local cS = false
	table.insert(W.C, b.InputBegan:Connect(function(i) if (i.UserInputType==_MB1 or i.UserInputType==_TC) and not cS then b.BackgroundTransparency=0.3 end end))
	table.insert(W.C, b.InputEnded:Connect(function(i) if i.UserInputType==_MB1 or i.UserInputType==_TC then b.BackgroundTransparency=0 end end))
	table.insert(W.C, b.MouseButton1Click:Connect(function()
		if cnf and not cS then
			cS = true; b.Text = "  Подтвердить?"; b.TextColor3 = T.Err
			task.delay(3, function() if cS and b.Parent then cS=false; b.Text="  "..tx; b.TextColor3=T.Txt end end)
			return
		end
		cS = false; b.Text = "  "..tx; b.TextColor3 = T.Txt; ss(cb)
	end))
	return b
end

local function _makeToggle(parent, W, tx, st, cb)
	local v = st == true
	local b = cr("TextButton",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=v and T.Acc or T.Btn,Text="  "..tx..(v and "  ✓" or "  ✗"),TextColor3=T.Txt,Font=T.Fnt,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,Parent=parent})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=b})
	local o = {}
	function o:Set(nv, sl) v=nv; b.BackgroundColor3=v and T.Acc or T.Btn; b.Text="  "..tx..(v and "  ✓" or "  ✗"); if not sl then ss(cb,v) end end
	function o:Get() return v end
	table.insert(W.C, b.MouseButton1Click:Connect(function() o:Set(not v) end))
	return o
end

local function _makeSlider(parent, W, tx, mn, mx, df, stp, cb)
	if not stp or stp <= 0 then stp = 1 end
	if mx <= mn then mx = mn + 1 end
	df = math.clamp(df, mn, mx)
	local dcs = stp < 1 and math.min(6, math.max(0, math.ceil(-math.log10(stp)))) or 0
	local fmt = "%." .. dcs .. "f"
	local inW = 38
	local f = cr("Frame",{Size=UDim2.new(1,0,0,38),BackgroundColor3=T.Btn,Parent=parent})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
	cr("TextLabel",{Size=UDim2.new(1,-inW-6,0,18),Position=UDim2.new(0,5,0,1),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
	local vl = cr("TextBox",{Size=UDim2.new(0,inW,0,16),Position=UDim2.new(1,-inW-4,0,2),BackgroundColor3=T.Bg,TextColor3=T.Acc,Font=T.Fnt,TextSize=12,Text=string.format(fmt,df),ClearTextOnFocus=false,TextXAlignment=Enum.TextXAlignment.Center,ClipsDescendants=true,Parent=f})
	cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=vl})
	if _mob() then vl.TextInputType = Enum.TextInputType.Number end
	local tr = cr("Frame",{Size=UDim2.new(1,-10,0,4),Position=UDim2.new(0,5,0,26),BackgroundColor3=T.Bg,Parent=f})
	cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=tr})
	local fill = cr("Frame",{Size=UDim2.new(math.clamp((df-mn)/(mx-mn),0,1),0,1,0),BackgroundColor3=T.Acc,Parent=tr})
	cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=fill})
	local hit = cr("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=tr})

	local o = {}
	function o:Get() return tonumber(vl.Text) or mn end
	function o:Set(nv, sl)
		local sv = string.format(fmt, math.clamp(math.floor((nv/stp)+0.5)*stp, mn, mx))
		local fv = tonumber(sv) or mn
		fill.Size = UDim2.new((fv-mn)/(mx-mn), 0, 1, 0)
		vl.Text = sv
		if not sl then ss(cb, fv) end
	end

	table.insert(W.C, hit.InputBegan:Connect(function(i)
		if i.UserInputType == _MB1 or i.UserInputType == _TC then
			-- Only one slider active at a time globally
			_activeSlider = {
				sD = true, sDi = i, lF = 0,
				ax = tr.AbsolutePosition.X, aw = tr.AbsoluteSize.X,
				mn = mn, mx = mx, stp = stp, fmt = fmt,
				fill = fill, vl = vl, cb = cb, tr = tr,
			}
			-- Immediate update on click
			local raw = mn + (mx - mn) * math.clamp((i.Position.X - _activeSlider.ax) / _activeSlider.aw, 0, 1)
			local sv = string.format(fmt, math.floor((raw / stp) + 0.5) * stp)
			local fv = tonumber(sv) or mn
			fill.Size = UDim2.new(math.clamp((fv-mn)/(mx-mn),0,1), 0, 1, 0)
			vl.Text = sv
			ss(cb, fv)
			_activeSlider.lF = os.clock()
		end
	end))

	table.insert(W.C, vl.FocusLost:Connect(function()
		local nv = tonumber(vl.Text)
		if nv then o:Set(nv, true); ss(cb, o:Get()) else vl.Text = string.format(fmt, mn) end
	end))

	return o
end

local function _makeInput(parent, W, tx, df, nO, cb)
	local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,Parent=parent})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
	cr("TextLabel",{Size=UDim2.new(0.55,0,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
	local tB = cr("TextBox",{Size=UDim2.new(0.45,-8,1,-6),Position=UDim2.new(0.55,3,0,3),BackgroundColor3=T.Bg,TextColor3=T.Acc,Font=T.Fnt,TextSize=12,Text=tostring(df),ClearTextOnFocus=false,ClipsDescendants=true,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
	if _mob() and nO then tB.TextInputType = Enum.TextInputType.Number end
	cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=tB})
	local lastValid = tostring(df)
	table.insert(W.C, tB.Focused:Connect(function() if nO then tB.Text="" end end))
	table.insert(W.C, tB.FocusLost:Connect(function()
		if nO and not tonumber(tB.Text) then tB.Text=lastValid; return end
		lastValid = tB.Text; ss(cb, tB.Text)
	end))
	local o = {}
	function o:Set(nv, sl) tB.Text=tostring(nv); lastValid=tostring(nv); if not sl then ss(cb,nv) end end
	function o:Get() return tB.Text end
	return o
end

local function _makeCycle(parent, W, tx, arr, cb)
	if not arr or #arr == 0 then return nil end
	local a = table.clone(arr)
	local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,Parent=parent})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
	cr("TextLabel",{Size=UDim2.new(0.5,0,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
	local b = cr("TextButton",{Size=UDim2.new(0.5,-8,1,-6),Position=UDim2.new(0.5,3,0,3),BackgroundColor3=T.Bg,TextColor3=T.Acc,Font=T.Fnt,TextSize=12,Text=tostring(a[1]),AutoButtonColor=false,Parent=f})
	cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=b})
	local idx = 1
	local o = {}
	function o:Set(val, sl)
		local sv = tostring(val)
		for i=1,#a do if tostring(a[i])==sv then idx=i; b.Text=tostring(a[idx]); if not sl then ss(cb,a[idx]) end; return end end
	end
	function o:Get() return a[idx] end
	table.insert(W.C, b.MouseButton1Click:Connect(function() idx=idx+1; if idx>#a then idx=1 end; b.Text=tostring(a[idx]); ss(cb,a[idx]) end))
	return o
end

local function _makeKeybind(parent, W, tx, dK, cb)
	if _mob() then return nil end
	local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,Parent=parent})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
	cr("TextLabel",{Size=UDim2.new(0.55,0,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
	local b = cr("TextButton",{Size=UDim2.new(0.45,-8,1,-6),Position=UDim2.new(0.55,3,0,3),BackgroundColor3=T.Bg,TextColor3=T.Dim,Font=T.Fnt,TextSize=12,Text=dK and dK.Name or "None",AutoButtonColor=false,Parent=f})
	cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=b})
	local k, w = dK, false

	table.insert(W.C, b.MouseButton1Click:Connect(function()
		if w then return end
		w = true; b.Text = "..."
		task.delay(10, function() if w and b.Parent then w=false; b.Text=k and k.Name or "None" end end)
	end))

	-- Use per-window consolidated keybind listener
	if not W._kbListening then
		W._kbListening = true
		W._kbWaiters = {}
		table.insert(W.C, UIS.InputBegan:Connect(function(i, g)
			if g or i.UserInputType ~= _KB then return end
			for _, entry in ipairs(W._kbWaiters) do
				if entry.w then entry.handler(i) end
			end
		end))
	end

	local entry = {w = false, handler = nil}
	entry.handler = function(i)
		if not entry.w then return end
		entry.w = false
		w = false
		if i.KeyCode == Enum.KeyCode.Escape then k=nil; b.Text="None" else k=i.KeyCode; b.Text=k.Name end
		ss(cb, k)
	end
	table.insert(W._kbWaiters, entry)

	-- Override the click to set the entry flag
	-- We already connected b.MouseButton1Click above, so we patch via the w variable sync
	-- Actually, let's re-wire: entry.w mirrors w
	local origConn = W.C[#W.C] -- the InputBegan conn is second-to-last, click is before
	-- Simpler: just sync entry.w with w in the click handler. Reconnect:
	W.C[#W.C-1]:Disconnect() -- disconnect the old click
	table.remove(W.C, #W.C-1)
	table.insert(W.C, b.MouseButton1Click:Connect(function()
		if w then return end
		w = true; entry.w = true; b.Text = "..."
		task.delay(10, function() if w and b.Parent then w=false; entry.w=false; b.Text=k and k.Name or "None" end end)
	end))

	local o = {}
	function o:Set(nk, sl) k=nk; b.Text=nk and nk.Name or "None"; if not sl then ss(cb,k) end end
	function o:Get() return k end
	return o
end

local function _makeDropdown(parent, W, tx, options, defaultIndex, cb)
	local a = table.clone(options or {})
	local idx = math.clamp(defaultIndex or 1, 1, math.max(1, #a))
	local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,ClipsDescendants=false,Parent=parent})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
	cr("TextLabel",{Size=UDim2.new(0.45,0,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
	local b = cr("TextButton",{Size=UDim2.new(0.55,-8,1,-6),Position=UDim2.new(0.45,3,0,3),BackgroundColor3=T.Bg,TextColor3=T.Acc,Font=T.Fnt,TextSize=12,Text=#a>0 and tostring(a[idx]) or "",AutoButtonColor=false,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
	cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=b})

	local listF = cr("Frame",{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,2),BackgroundColor3=T.Btn,Visible=false,ZIndex=100,ClipsDescendants=true,Parent=f})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=listF})
	local listLL = cr("UIListLayout",{Padding=UDim.new(0,1),SortOrder=Enum.SortOrder.LayoutOrder,Parent=listF})
	cr("UIPadding",{PaddingLeft=UDim.new(0,2),PaddingRight=UDim.new(0,2),PaddingTop=UDim.new(0,2),PaddingBottom=UDim.new(0,2),Parent=listF})

	local optBtns = {}
	local isOpen = false

	local function buildList()
		for _, ob in ipairs(optBtns) do ob:Destroy() end
		table.clear(optBtns)
		for i, v in ipairs(a) do
			local ob = cr("TextButton",{Size=UDim2.new(1,0,0,20),BackgroundColor3=T.Bg,TextColor3=(i==idx) and T.Acc or T.Txt,Font=T.Fnt,TextSize=12,Text="  "..tostring(v),TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,ZIndex=101,Parent=listF})
			cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=ob})
			table.insert(optBtns, ob)
			table.insert(W.C, ob.MouseButton1Click:Connect(function()
				idx = i; b.Text = tostring(a[idx])
				for j, ob2 in ipairs(optBtns) do ob2.TextColor3 = (j==idx) and T.Acc or T.Txt end
				isOpen = false; listF.Visible = false
				ss(cb, a[idx])
			end))
		end
		listF.Size = UDim2.new(1, 0, 0, #a * 21 + 4)
	end
	buildList()

	table.insert(W.C, b.MouseButton1Click:Connect(function()
		isOpen = not isOpen; listF.Visible = isOpen
	end))

	-- Close on click outside (simple: any other click on the window)
	table.insert(W.C, UIS.InputBegan:Connect(function(i)
		if not isOpen then return end
		if i.UserInputType == _MB1 or i.UserInputType == _TC then
			task.defer(function()
				-- Check if mouse is outside listF bounds
				if not listF or not listF.Parent then return end
				local mp = i.Position
				local ap = listF.AbsolutePosition
				local as = listF.AbsoluteSize
				local bp = b.AbsolutePosition
				local bs = b.AbsoluteSize
				local inList = mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y
				local inBtn = mp.X >= bp.X and mp.X <= bp.X+bs.X and mp.Y >= bp.Y and mp.Y <= bp.Y+bs.Y
				if not inList and not inBtn then isOpen=false; listF.Visible=false end
			end)
		end
	end))

	local o = {}
	function o:Get() return #a > 0 and a[idx] or nil end
	function o:Set(val, sl)
		local sv = tostring(val)
		for i=1,#a do if tostring(a[i])==sv then idx=i; b.Text=tostring(a[idx]); if not sl then ss(cb,a[idx]) end; return end end
	end
	function o:SetOptions(newTbl)
		a = table.clone(newTbl or {})
		idx = math.clamp(idx, 1, math.max(1, #a))
		b.Text = #a > 0 and tostring(a[idx]) or ""
		buildList()
	end
	return o
end

local function _makeColorPicker(parent, W, tx, defaultColor, cb)
	defaultColor = defaultColor or Color3.fromRGB(255,0,0)
	local h, s, v = Color3.toHSV(defaultColor)
	local currentColor = defaultColor

	local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,ClipsDescendants=false,Parent=parent})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
	cr("TextLabel",{Size=UDim2.new(1,-30,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
	local preview = cr("TextButton",{Size=UDim2.new(0,20,0,20),Position=UDim2.new(1,-24,0,2),BackgroundColor3=currentColor,Text="",AutoButtonColor=false,Parent=f})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=preview})

	-- Picker panel (inline, below)
	local pickerH = 90
	local panel = cr("Frame",{Size=UDim2.new(1,0,0,pickerH),Position=UDim2.new(0,0,1,2),BackgroundColor3=T.Bg,Visible=false,ZIndex=100,ClipsDescendants=true,Parent=f})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=panel})

	-- SV square (left side, 70x70)
	local svSize = 70
	local svF = cr("Frame",{Size=UDim2.new(0,svSize,0,svSize),Position=UDim2.new(0,4,0,4),BackgroundColor3=Color3.fromHSV(h,1,1),ZIndex=101,Parent=panel})
	cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=svF})
	-- White gradient left->right (saturation)
	local wGrad = cr("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(1,1,1),ZIndex=102,Parent=svF})
	cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=wGrad})
	cr("UIGradient",{Color=ColorSequence.new(Color3.new(1,1,1),Color3.new(1,1,1)),Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)}),Parent=wGrad})
	-- Black gradient top->bottom (value)
	local bGrad = cr("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(0,0,0),ZIndex=103,Parent=svF})
	cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=bGrad})
	cr("UIGradient",{Color=ColorSequence.new(Color3.new(0,0,0),Color3.new(0,0,0)),Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(1,0)}),Rotation=90,Parent=bGrad})
	local svHit = cr("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=104,AutoButtonColor=false,Parent=svF})
	-- SV cursor
	local svCur = cr("Frame",{Size=UDim2.new(0,6,0,6),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(s,0,1-v,0),BackgroundColor3=T.Txt,ZIndex=105,Parent=svF})
	cr("UICorner",{CornerRadius=UDim.new(1,0),Parent=svCur})

	-- Hue bar (right side, vertical, 16 wide)
	local hueBarW = 16
	local hueF = cr("Frame",{Size=UDim2.new(0,hueBarW,0,svSize),Position=UDim2.new(1,-hueBarW-4,0,4),BackgroundColor3=Color3.new(1,1,1),ZIndex=101,Parent=panel})
	cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=hueF})
	-- Build hue gradient with 7 keypoints
	local hueKP = {}
	for i=0,6 do
		table.insert(hueKP, ColorSequenceKeypoint.new(i/6, Color3.fromHSV(i/6,1,1)))
	end
	cr("UIGradient",{Color=ColorSequence.new(hueKP),Rotation=90,Parent=hueF})
	local hueHit = cr("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=102,AutoButtonColor=false,Parent=hueF})
	local hueCur = cr("Frame",{Size=UDim2.new(1,2,0,4),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,h,0),BackgroundColor3=T.Txt,ZIndex=103,Parent=hueF})
	cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=hueCur})

	local isOpen = false
	local svDrag, hueDrag = false, false

	local function updateColor()
		currentColor = Color3.fromHSV(h, s, v)
		preview.BackgroundColor3 = currentColor
		svF.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
		svCur.Position = UDim2.new(s, 0, 1-v, 0)
		hueCur.Position = UDim2.new(0.5, 0, h, 0)
		ss(cb, currentColor)
	end

	table.insert(W.C, preview.MouseButton1Click:Connect(function()
		isOpen = not isOpen; panel.Visible = isOpen
	end))

	-- SV drag
	table.insert(W.C, svHit.InputBegan:Connect(function(i)
		if i.UserInputType == _MB1 or i.UserInputType == _TC then
			svDrag = true
			local ap = svF.AbsolutePosition; local as = svF.AbsoluteSize
			s = math.clamp((i.Position.X - ap.X) / as.X, 0, 1)
			v = math.clamp(1 - (i.Position.Y - ap.Y) / as.Y, 0, 1)
			updateColor()
		end
	end))

	-- Hue drag
	table.insert(W.C, hueHit.InputBegan:Connect(function(i)
		if i.UserInputType == _MB1 or i.UserInputType == _TC then
			hueDrag = true
			local ap = hueF.AbsolutePosition; local as = hueF.AbsoluteSize
			h = math.clamp((i.Position.Y - ap.Y) / as.Y, 0, 1)
			updateColor()
		end
	end))

	-- Move handler for color picker drags
	local cpID = tostring(f) .. "_cp"
	_dragCbs[cpID] = function(i)
		if svDrag then
			local ap = svF.AbsolutePosition; local as = svF.AbsoluteSize
			s = math.clamp((i.Position.X - ap.X) / as.X, 0, 1)
			v = math.clamp(1 - (i.Position.Y - ap.Y) / as.Y, 0, 1)
			updateColor()
		elseif hueDrag then
			local ap = hueF.AbsolutePosition; local as = hueF.AbsoluteSize
			h = math.clamp((i.Position.Y - ap.Y) / as.Y, 0, 1)
			updateColor()
		end
	end

	_dragEndCbs[cpID] = function(i)
		if i.UserInputType == _MB1 or i.UserInputType == _TC then
			svDrag = false; hueDrag = false
		end
	end

	-- Store cleanup reference
	table.insert(W.C, {Disconnect = function()
		_dragCbs[cpID] = nil
		_dragEndCbs[cpID] = nil
	end})

	-- Close on outside click
	table.insert(W.C, UIS.InputBegan:Connect(function(i)
		if not isOpen then return end
		if i.UserInputType == _MB1 or i.UserInputType == _TC then
			task.defer(function()
				if not panel or not panel.Parent then return end
				local mp = i.Position
				local ap = panel.AbsolutePosition; local as = panel.AbsoluteSize
				local pp = preview.AbsolutePosition; local ps = preview.AbsoluteSize
				local inP = mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y
				local inB = mp.X >= pp.X and mp.X <= pp.X+ps.X and mp.Y >= pp.Y and mp.Y <= pp.Y+ps.Y
				if not inP and not inB then isOpen=false; panel.Visible=false end
			end)
		end
	end))

	local o = {}
	function o:Get() return currentColor end
	function o:Set(c3, sl)
		h, s, v = Color3.toHSV(c3)
		currentColor = c3
		preview.BackgroundColor3 = c3
		svF.BackgroundColor3 = Color3.fromHSV(h,1,1)
		svCur.Position = UDim2.new(s,0,1-v,0)
		hueCur.Position = UDim2.new(0.5,0,h,0)
		if not sl then ss(cb, currentColor) end
	end
	return o
end

-----------------------------------------------------------------------
-- CreateWindow
-----------------------------------------------------------------------
function AzraelUI:CreateWindow(title, cfg)
	if _wins[title] then _wins[title]:Destroy() end
	cfg = cfg or {}
	local W = {C={}, Inp={}, _sections={}, _activeSection=nil, _kbListening=false, _kbWaiters={}}

	local WIN_W = T.W
	local TOP_H = 26
	local TAB_H = 22
	local PAD = 4
	local IPAD = 6

	local sg = cr("ScreenGui",{Name="AzF_"..title,ResetOnSpawn=false,DisplayOrder=99998,ZIndexBehavior=Enum.ZIndexBehavior.Sibling,Parent=CG})
	local ps = cfg.pos or UDim2.new(0.5,-95,0.5,-120)
	local mf = cr("Frame",{Size=UDim2.new(0,WIN_W,0,TOP_H),Position=ps,BackgroundColor3=T.Bg,Active=true,ClipsDescendants=true,Parent=sg})
	cr("UICorner",{CornerRadius=UDim.new(0,6),Parent=mf})

	local tb = cr("Frame",{Size=UDim2.new(1,0,0,TOP_H),BackgroundColor3=T.Top,ClipsDescendants=false,Parent=mf})
	cr("UICorner",{CornerRadius=UDim.new(0,6),Parent=tb})
	cr("Frame",{Size=UDim2.new(1,0,0,6),Position=UDim2.new(0,0,1,-6),BackgroundColor3=T.Top,BorderSizePixel=0,Parent=tb})
	cr("TextLabel",{Size=UDim2.new(1,-52,1,0),Position=UDim2.new(0,7,0,0),BackgroundTransparency=1,Text=title,TextColor3=T.Txt,Font=T.Fnt,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,Parent=tb})
	local tg = cr("TextButton",{Size=UDim2.new(0,22,0,22),Position=UDim2.new(1,-46,0,2),BackgroundTransparency=1,Text="-",TextColor3=T.Dim,Font=T.Fnt,TextSize=16,AutoButtonColor=false,Parent=tb})
	local cl = cr("TextButton",{Size=UDim2.new(0,22,0,22),Position=UDim2.new(1,-24,0,2),BackgroundTransparency=1,Text="×",TextColor3=T.Err,Font=T.Fnt,TextSize=16,AutoButtonColor=false,Parent=tb})

	local tabRow = cr("Frame",{Size=UDim2.new(1,0,0,TAB_H),Position=UDim2.new(0,0,0,TOP_H),BackgroundColor3=T.Top,Visible=false,ClipsDescendants=true,Parent=mf})
	cr("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=T.Sep,BorderSizePixel=0,Parent=tabRow})
	cr("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,1),Parent=tabRow})
	cr("UIPadding",{PaddingLeft=UDim.new(0,2),PaddingTop=UDim.new(0,2),PaddingBottom=UDim.new(0,2),Parent=tabRow})

	local minimized = false
	local _resizeDirty = false

	local function _resize()
		if minimized then return end
		if _resizeDirty then return end
		_resizeDirty = true
		task.defer(function()
			_resizeDirty = false
			if minimized then return end
			local hasTabs = #W._sections > 0
			tabRow.Visible = hasTabs
			local base = TOP_H + (hasTabs and TAB_H or 0)
			local secH = 0
			if W._activeSection then
				local ll = W._activeSection._layout
				if ll and ll.Parent then
					secH = ll.AbsoluteContentSize.Y + (PAD * 2)
				end
			end
			mf.Size = UDim2.new(0, WIN_W, 0, base + secH)
		end)
	end

	-- Helper: compute section Y position
	local function _secY()
		return TOP_H + (#W._sections > 0 and TAB_H or 0)
	end

	function W:AddSection(name)
		tabRow.Visible = true
		local sf = cr("Frame",{
			Size=UDim2.new(1,0,0,0),
			Position=UDim2.new(0,0,0,TOP_H+TAB_H),
			BackgroundColor3=T.Bg,
			Visible=false,
			ClipsDescendants=false,
			Parent=mf,
		})
		local ll = cr("UIListLayout",{Padding=UDim.new(0,3),SortOrder=Enum.SortOrder.LayoutOrder,Parent=sf})
		cr("UIPadding",{PaddingLeft=UDim.new(0,IPAD),PaddingRight=UDim.new(0,IPAD),PaddingTop=UDim.new(0,PAD),PaddingBottom=UDim.new(0,PAD),Parent=sf})

		local sec = {_frame=sf, _layout=ll, _name=name}
		table.insert(W._sections, sec)

		-- Update flat sec position if it exists (sections push it down)
		if W._flatSec then
			W._flatSec._frame.Position = UDim2.new(0, 0, 0, TOP_H + TAB_H)
		end

		local tabCount = #W._sections
		local tabW = math.max(30, math.floor((WIN_W - 4) / tabCount))
		for _, s2 in ipairs(W._sections) do
			if s2._tab then
				s2._tab.Size = UDim2.new(0, tabW, 1, 0)
			end
		end

		local tab = cr("TextButton",{
			Size=UDim2.new(0,tabW,1,0),
			BackgroundColor3=T.Btn,
			Text=name,
			TextColor3=T.Dim,
			Font=T.Fnt,
			TextSize=12,
			AutoButtonColor=false,
			TextTruncate=Enum.TextTruncate.AtEnd,
			Parent=tabRow,
		})
		cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=tab})
		sec._tab = tab

		local function activate()
			for _, s2 in ipairs(W._sections) do
				s2._frame.Visible = false
				s2._tab.BackgroundColor3 = T.Btn
				s2._tab.TextColor3 = T.Dim
			end
			if W._flatSec then W._flatSec._frame.Visible = false end
			sf.Visible = true
			tab.BackgroundColor3 = T.Bg
			tab.TextColor3 = T.Acc
			W._activeSection = sec
			_resize()
		end

		if #W._sections == 1 then activate() end
		table.insert(W.C, tab.MouseButton1Click:Connect(activate))
		table.insert(W.C, ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			if W._activeSection == sec then _resize() end
		end))

		local proxy = {_frame=sf, _layout=ll, C=W.C, Inp=W.Inp}
		function proxy:AddSeparator() return _makeSeparator(sf) end
		function proxy:AddLabel(t) return _makeLabel(sf, t) end
		function proxy:AddButton(t, c, cn) return _makeButton(sf, W, t, c, cn) end
		function proxy:AddToggle(t, st2, c) return _makeToggle(sf, W, t, st2, c) end
		function proxy:AddSlider(t, mn2, mx2, df2, stp2, c) return _makeSlider(sf, W, t, mn2, mx2, df2, stp2, c) end
		function proxy:AddInput(t, df2, nO2, c) return _makeInput(sf, W, t, df2, nO2, c) end
		function proxy:AddCycle(t, arr2, c) return _makeCycle(sf, W, t, arr2, c) end
		function proxy:AddKeybind(t, dK2, c) return _makeKeybind(sf, W, t, dK2, c) end
		function proxy:AddDropdown(t, opts, di, c) return _makeDropdown(sf, W, t, opts, di, c) end
		function proxy:AddColorPicker(t, dc, c) return _makeColorPicker(sf, W, t, dc, c) end

		return proxy
	end

	-- Flat (no-section) helpers
	local function _ensureFlat()
		if not W._flatSec then
			local yPos = _secY()
			local sf = cr("Frame",{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,yPos),BackgroundColor3=T.Bg,Visible=true,ClipsDescendants=false,Parent=mf})
			local ll = cr("UIListLayout",{Padding=UDim.new(0,3),SortOrder=Enum.SortOrder.LayoutOrder,Parent=sf})
			cr("UIPadding",{PaddingLeft=UDim.new(0,IPAD),PaddingRight=UDim.new(0,IPAD),PaddingTop=UDim.new(0,PAD),PaddingBottom=UDim.new(0,PAD),Parent=sf})
			W._flatSec = {_frame=sf, _layout=ll}
			if not W._activeSection then
				W._activeSection = W._flatSec
			end
			table.insert(W.C, ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
				if W._activeSection == W._flatSec then _resize() end
			end))
		end
		-- Always update position in case sections were added after
		W._flatSec._frame.Position = UDim2.new(0, 0, 0, _secY())
		return W._flatSec._frame
	end

	function W:AddSeparator() return _makeSeparator(_ensureFlat()) end
	function W:AddLabel(t) return _makeLabel(_ensureFlat(), t) end
	function W:AddButton(t, c, cn) _ensureFlat(); return _makeButton(W._flatSec._frame, W, t, c, cn) end
	function W:AddToggle(t, st2, c) _ensureFlat(); return _makeToggle(W._flatSec._frame, W, t, st2, c) end
	function W:AddSlider(t, mn2, mx2, df2, stp2, c) _ensureFlat(); return _makeSlider(W._flatSec._frame, W, t, mn2, mx2, df2, stp2, c) end
	function W:AddInput(t, df2, nO2, c) _ensureFlat(); return _makeInput(W._flatSec._frame, W, t, df2, nO2, c) end
	function W:AddCycle(t, arr2, c) _ensureFlat(); return _makeCycle(W._flatSec._frame, W, t, arr2, c) end
	function W:AddKeybind(t, dK2, c) _ensureFlat(); return _makeKeybind(W._flatSec._frame, W, t, dK2, c) end
	function W:AddDropdown(t, opts, di, c) _ensureFlat(); return _makeDropdown(W._flatSec._frame, W, t, opts, di, c) end
	function W:AddColorPicker(t, dc, c) _ensureFlat(); return _makeColorPicker(W._flatSec._frame, W, t, dc, c) end

	-- Dragging
	local dr, di2, dsX, dsY, spX, spY = false, nil, 0, 0, 0, 0
	table.insert(W.C, tb.InputBegan:Connect(function(i)
		if not minimized and (i.UserInputType == _MB1 or i.UserInputType == _TC) then
			dr = true; dsX = i.Position.X; dsY = i.Position.Y
			spX = mf.Position.X.Offset; spY = mf.Position.Y.Offset; di2 = i
		end
	end))

	_wId = _wId + 1
	local inID = _wId

	_dragEndCbs[inID] = function(i)
		if dr and (i.UserInputType == _MB1 or i.UserInputType == _TC) then dr = false; di2 = nil end
	end

	_dragCbs[inID] = function(i)
		if dr and i == di2 then
			mf.Position = UDim2.new(mf.Position.X.Scale, spX + (i.Position.X - dsX), mf.Position.Y.Scale, spY + (i.Position.Y - dsY))
		end
	end

	-- Minimize
	table.insert(W.C, tg.MouseButton1Click:Connect(function()
		minimized = not minimized
		tg.Text = minimized and "+" or "-"
		if minimized then
			mf.Size = UDim2.new(0, WIN_W, 0, TOP_H)
			for _, s2 in ipairs(W._sections) do s2._frame.Visible = false end
			tabRow.Visible = false
			if W._flatSec then W._flatSec._frame.Visible = false end
		else
			tabRow.Visible = #W._sections > 0
			if W._activeSection then
				for _, s2 in ipairs(W._sections) do
					s2._frame.Visible = (s2 == W._activeSection)
				end
			end
			-- Show flatSec if it exists AND (no sections or activeSection is flatSec)
			if W._flatSec then
				if #W._sections == 0 or W._activeSection == W._flatSec then
					W._flatSec._frame.Visible = true
				else
					W._flatSec._frame.Visible = false
				end
			end
			_resize()
		end
	end))

	-- SetKeybind (module-level hotkey)
	function W:SetKeybind(key, callback)
		key = key or Enum.KeyCode.RightShift
		callback = callback or function() W:SetVisible() end
		_keybindMap[inID] = {key = key, cb = callback}
	end

	local _d = false
	function W:Destroy()
		if _d then return end; _d = true
		_wins[title] = nil
		_dragCbs[inID] = nil
		_dragEndCbs[inID] = nil
		_keybindMap[inID] = nil
		for _, c in pairs(W.C) do
			if type(c) == "table" and c.Disconnect then
				pcall(function() c:Disconnect() end)
			elseif typeof(c) == "RBXScriptConnection" then
				c:Disconnect()
			end
		end
		table.clear(W.C)
		table.clear(W.Inp)
		W._sections = nil
		W._flatSec = nil
		W._activeSection = nil
		W._kbWaiters = nil
		sg:Destroy()
	end

	function W:SetVisible(v)
		if v == nil then sg.Enabled = not sg.Enabled else sg.Enabled = v == true end
	end
	function W:Hide() sg.Enabled = false end
	function W:Show() sg.Enabled = true end

	table.insert(W.C, cl.MouseButton1Click:Connect(function() W:Destroy() end))
	table.insert(W.C, sg.Destroying:Connect(function() W:Destroy() end))
	_wins[title] = W
	return W
end

return AzraelUI
