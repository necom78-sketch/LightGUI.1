        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=panel})
        local svSize = 70
        local svF = cr("Frame",{Size=UDim2.new(0,svSize,0,svSize),Position=UDim2.new(0,4,0,4),BackgroundColor3=Color3.fromHSV(h,1,1),ZIndex=101,Parent=panel})
        cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=svF})
        local wGrad = cr("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(1,1,1),ZIndex=102,Parent=svF})
        cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=wGrad})
        cr("UIGradient",{Color=ColorSequence.new(Color3.new(1,1,1),Color3.new(1,1,1)),Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)}),Parent=wGrad})
        local bGrad = cr("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(0,0,0),ZIndex=103,Parent=svF})
        cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=bGrad})
        cr("UIGradient",{Color=ColorSequence.new(Color3.new(0,0,0),Color3.new(0,0,0)),Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(1,0)}),Rotation=90,Parent=bGrad})
        local svHit = cr("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=104,AutoButtonColor=false,Parent=svF})
        local svCur = cr("Frame",{Size=UDim2.new(0,6,0,6),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(s,0,1-v,0),BackgroundColor3=T.Txt,ZIndex=105,Parent=svF})
        cr("UICorner",{CornerRadius=UDim.new(1,0),Parent=svCur})
        local hueBarW = 16
        local hueF = cr("Frame",{Size=UDim2.new(0,hueBarW,0,svSize),Position=UDim2.new(1,-hueBarW-4,0,4),BackgroundColor3=Color3.new(1,1,1),ZIndex=101,Parent=panel})
        cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=hueF})
        local hueKP = {}
        for i=0,6 do
            table.insert(hueKP, ColorSequenceKeypoint.new(i/6, Color3.fromHSV(i/6,1,1)))
        end
        cr("UIGradient",{Color=ColorSequence.new(hueKP),Rotation=90,Parent=hueF})
        local hueHit = cr("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=102,AutoButtonColor=false,Parent=hueF})
        local hueCur = cr("Frame",{Size=UDim2.new(1,2,0,4),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,h,0),BackgroundColor3=T.Txt,ZIndex=103,Parent=hueF})
        cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=hueCur})
        local isOpen = false
        local svDrag, hueDrag = false, false
        local cpID = "cp_"..tostring(#W.C)
        local closeTimer = nil
        local function updateColor()
            if not svCur or not svCur.Parent then return end
            currentColor = Color3.fromHSV(h, s, v)
            preview.BackgroundColor3 = currentColor
            svF.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            svCur.Position = UDim2.new(s, 0, 1-v, 0)
            hueCur.Position = UDim2.new(0.5, 0, h, 0)
            ss(cb, currentColor)
        end
        local function openClose()
            isOpen = not isOpen
            panel.Visible = isOpen
            if isOpen then
                if closeTimer then task.cancel(closeTimer) end
                closeTimer = task.delay(10, function()
                    if isOpen then isOpen = false; panel.Visible = false; openClose() end
                end)
                _dragCbs[cpID] = function(i)
                    if svDrag then
                        if not svF or not svF.Parent then svDrag = false; return end
                        local ap = svF.AbsolutePosition; local as = svF.AbsoluteSize
                        s = math.clamp((i.Position.X - ap.X) / as.X, 0, 1)
                        v = math.clamp(1 - (i.Position.Y - ap.Y) / as.Y, 0, 1)
                        updateColor()
                    elseif hueDrag then
                        if not hueF or not hueF.Parent then hueDrag = false; return end
                        local ap = hueF.AbsolutePosition; local as = hueF.AbsoluteSize
                        h = math.clamp((i.Position.Y - ap.Y) / as.Y, 0, 1)
                        updateColor()
                    end
                end
                _dragEndCbs[cpID] = function(i)
                    if i.UserInputType == _MB1 or i.UserInputType == _TC then
                        svDrag = false; hueDrag = false
                    end
                end
                _hasActiveDrags = true
            else
                _dragCbs[cpID] = nil
                _dragEndCbs[cpID] = nil
                if closeTimer then task.cancel(closeTimer); closeTimer = nil end
                if not next(_dragCbs) then _hasActiveDrags = false end
            end
        end
        table.insert(W.C, preview.MouseButton1Click:Connect(openClose))
        table.insert(W.C, svHit.InputBegan:Connect(function(i)
            if i.UserInputType == _MB1 or i.UserInputType == _TC then
                if not svF or not svF.Parent then return end
                svDrag = true
                local ap = svF.AbsolutePosition; local as = svF.AbsoluteSize
                s = math.clamp((i.Position.X - ap.X) / as.X, 0, 1)
                v = math.clamp(1 - (i.Position.Y - ap.Y) / as.Y, 0, 1)
                updateColor()
            end
        end))
        table.insert(W.C, hueHit.InputBegan:Connect(function(i)
            if i.UserInputType == _MB1 or i.UserInputType == _TC then
                if not hueF or not hueF.Parent then return end
                hueDrag = true
                local ap = hueF.AbsolutePosition; local as = hueF.AbsoluteSize
                h = math.clamp((i.Position.Y - ap.Y) / as.Y, 0, 1)
                updateColor()
            end
        end))
        table.insert(W.C, {Disconnect = function()
            _dragCbs[cpID] = nil; _dragEndCbs[cpID] = nil
            if not next(_dragCbs) then _hasActiveDrags = false end
        end})
        _inputBeganCbs[cpID] = function(i)
            if not isOpen then return end
            task.defer(function()
                if not panel or not panel.Parent then return end
                local mp = i.Position
                local ap = panel.AbsolutePosition; local as = panel.AbsoluteSize
                local pp = preview.AbsolutePosition; local ps = preview.AbsoluteSize
                local inP = mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y
                local inB = mp.X >= pp.X and mp.X <= pp.X+ps.X and mp.Y >= pp.Y and mp.Y <= pp.Y+ps.Y
                if not inP and not inB then isOpen = false; panel.Visible = false; openClose() end
            end)
        end
        table.insert(W.C, {Disconnect = function() _inputBeganCbs[cpID] = nil end})
        local function close()
            if isOpen then isOpen = false; panel.Visible = false; openClose() end
        end
        local o = {}
        function o:Get() return currentColor end
        function o:Set(c3, sl)
            h, s, v = Color3.toHSV(c3)
            currentColor = c3
            preview.BackgroundColor3 = c3
            if svF and svF.Parent then
                svF.BackgroundColor3 = Color3.fromHSV(h,1,1)
                svCur.Position = UDim2.new(s,0,1-v,0)
                hueCur.Position = UDim2.new(0.5,0,h,0)
            end
            if not sl then ss(cb, currentColor) end
        end
        function o:Close() close() end
        if not W._colorpickers then W._colorpickers = {} end
        table.insert(W._colorpickers, o)
        table.insert(W.C, {Disconnect = function()
            if W._colorpickers then
                local idx2 = _tfind(W._colorpickers, o)
                if idx2 then table.remove(W._colorpickers, idx2) end
            end
        end})
        return o
    end

    function AzraelUI:CreateWindow(title, cfg)
        assert(type(title) == "string" and #title > 0, "[AzUI] title must be non-empty string")
        _ensureModuleConns()
        local oldW = _wins[title]
        if oldW then oldW:Destroy() end
        cfg = cfg or {}
        local W = {C={}, Inp={}, _sections={}, _activeSection=nil, _kbListening=false, _kbWaiters={},
            _dropdowns = {},
            _colorpickers = {},
            _keybinds = {},
        }
        _wins[title] = W
        local WIN_W = T.W
        local TOP_H, TAB_H, PAD, IPAD = 26, 22, 4, 6
        local sgName = _randomName()
        local sg = cr("ScreenGui",{Name=sgName,ResetOnSpawn=false,DisplayOrder=99998,ZIndexBehavior=Enum.ZIndexBehavior.Sibling,Parent=CG})
        local ps = cfg.pos or UDim2.new(0,0,0,0)
        local mf = cr("Frame",{Size=UDim2.new(0,WIN_W,0,TOP_H),Position=ps,BackgroundColor3=T.Bg,Active=true,ClipsDescendants=true,Parent=sg})
        cr("UICorner",{CornerRadius=UDim.new(0,6),Parent=mf})
        if not cfg.pos then
            local vps = CAM and CAM.ViewportSize or Vector2.new(1920,1080)
            mf.Position = UDim2.new(0, math.floor(vps.X/2 - WIN_W/2), 0, math.floor(vps.Y/2 - 120))
        end
        local tb = cr("Frame",{Size=UDim2.new(1,0,0,TOP_H),BackgroundColor3=T.Top,ClipsDescendants=false,Parent=mf})
        cr("UICorner",{CornerRadius=UDim.new(0,6),Parent=tb})
        cr("Frame",{Size=UDim2.new(1,0,0,6),Position=UDim2.new(0,0,1,-6),BackgroundColor3=T.Top,BorderSizePixel=0,Parent=tb})
        cr("TextLabel",{Size=UDim2.new(1,-52,1,0),Position=UDim2.new(0,7,0,0),BackgroundTransparency=1,Text=title,TextColor3=T.Txt,Font=T.Fnt,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=tb})
        local tg = cr("TextButton",{Size=UDim2.new(0,22,0,22),Position=UDim2.new(1,-46,0,2),BackgroundTransparency=1,Text="-",TextColor3=T.Dim,Font=T.Fnt,TextSize=16,AutoButtonColor=false,Parent=tb})
        local cl = cr("TextButton",{Size=UDim2.new(0,22,0,22),Position=UDim2.new(1,-24,0,2),BackgroundTransparency=1,Text="×",TextColor3=T.Err,Font=T.Fnt,TextSize=16,AutoButtonColor=false,Parent=tb})
        local tabRow = cr("Frame",{Size=UDim2.new(1,0,0,TAB_H),Position=UDim2.new(0,0,0,TOP_H),BackgroundColor3=T.Top,Visible=false,ClipsDescendants=true,Parent=mf})
        cr("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=T.Sep,BorderSizePixel=0,Parent=tabRow})
        cr("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,1),Parent=tabRow})
        cr("UIPadding",{PaddingLeft=UDim.new(0,2),PaddingTop=UDim.new(0,2),PaddingBottom=UDim.new(0,2),Parent=tabRow})
        local minimized = false
        local _resizeDirty = false
        local function _resize()
            if minimized then return end
            if _resizeDirty then return end
            _resizeDirty = true
            task.defer(function()
                _resizeDirty = false
                if not W._sections then return end
                if minimized then return end
                local hasTabs = #W._sections > 0
                tabRow.Visible = hasTabs
                local base = TOP_H + (hasTabs and TAB_H or 0)
                local secH = 0
                if W._activeSection and W._activeSection ~= W._flatSec then
                    local ll = W._activeSection._layout
                    if ll and ll.Parent then
                        secH = ll.AbsoluteContentSize.Y + (PAD * 2)
                    end
                end
                local flatH = 0
                if W._flatSec then
                    local fll = W._flatSec._layout
                    if fll and fll.Parent then
                        flatH = fll.AbsoluteContentSize.Y + (PAD * 2)
                    end
                end
                mf.Size = UDim2.new(0, WIN_W, 0, base + secH + flatH)
                if W._flatSec and W._flatSec._frame then
                    W._flatSec._frame.Position = UDim2.new(0, 0, 0, base + secH)
                end
            end)
        end
        local function _secY()
            return TOP_H + (#W._sections > 0 and TAB_H or 0)
        end
        function W:AddSection(name)
            tabRow.Visible = true
            local sf = cr("Frame",{
                Size=UDim2.new(1,0,0,0),
                Position=UDim2.new(0,0,0,TOP_H+TAB_H),
                BackgroundColor3=T.Bg,
                Visible=false,
                ClipsDescendants=false,
                Parent=mf,
            })
            local ll = cr("UIListLayout",{Padding=UDim.new(0,3),SortOrder=Enum.SortOrder.LayoutOrder,Parent=sf})
            cr("UIPadding",{PaddingLeft=UDim.new(0,IPAD),PaddingRight=UDim.new(0,IPAD),PaddingTop=UDim.new(0,PAD),PaddingBottom=UDim.new(0,PAD),Parent=sf})
            local sec = {_frame=sf, _layout=ll, _name=name}
            table.insert(W._sections, sec)
            local tabCount = #W._sections
            local tabW = math.max(30, math.floor((WIN_W - 4) / tabCount))
            for _, s2 in ipairs(W._sections) do
                if s2._tab then
                    s2._tab.Size = UDim2.new(0, tabW, 1, 0)
                end
            end
            local tab = cr("TextButton",{
                Size=UDim2.new(0,tabW,1,0),
                BackgroundColor3=T.Btn,
                Text=name,
                TextColor3=T.Dim,
                Font=T.Fnt,
                TextSize=12,
                AutoButtonColor=false,
                TextTruncate=Enum.TextTruncate.AtEnd,
                Parent=tabRow,
            })
            cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=tab})
            sec._tab = tab
            local function activate()
                for _, s2 in ipairs(W._sections) do
                    s2._frame.Visible = false
                    s2._tab.BackgroundColor3 = T.Btn
                    s2._tab.TextColor3 = T.Dim
                end
                sf.Visible = true
                tab.BackgroundColor3 = T.Bg
                tab.TextColor3 = T.Acc
                W._activeSection = sec
                if W._flatSec then W._flatSec._frame.Visible = true end
                _resize()
            end
            if #W._sections == 1 then activate() end
            table.insert(W.C, tab.MouseButton1Click:Connect(activate))
            table.insert(W.C, ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                if W._activeSection == sec then _resize() end
            end))
            local proxy = {_frame=sf, _layout=ll, C=W.C, Inp=W.Inp}
            function proxy:AddSeparator() return _makeSeparator(sf) end
            function proxy:AddLabel(t) return _makeLabel(sf, t) end
            function proxy:AddButton(t, c, cn) return _makeButton(sf, W, t, c, cn) end
            function proxy:AddToggle(t, st2, c) return _makeToggle(sf, W, t, st2, c) end
            function proxy:AddSlider(t, mn2, mx2, df2, stp2, c) return _makeSlider(sf, W, t, mn2, mx2, df2, stp2, c) end
            function proxy:AddInput(t, df2, nO2, c) return _makeInput(sf, W, t, df2, nO2, c) end
            function proxy:AddCycle(t, arr2, c) return _makeCycle(sf, W, t, arr2, c) end
            function proxy:AddKeybind(t, dK2, c)
                local kb = _makeKeybind(sf, W, t, dK2, c)
                table.insert(W._keybinds, kb)
                return kb
            end
            function proxy:AddDropdown(t, opts, di, c) return _makeDropdown(sf, W, t, opts, di, c) end
            function proxy:AddColorPicker(t, dc, c) return _makeColorPicker(sf, W, t, dc, c) end
            return proxy
        end
        local function _ensureFlat()
            if not W._flatSec then
                local yPos = _secY()
                local sf = cr("Frame",{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,yPos),BackgroundColor3=T.Bg,Visible=true,ClipsDescendants=false,Parent=mf})
                local ll = cr("UIListLayout",{Padding=UDim.new(0,3),SortOrder=Enum.SortOrder.LayoutOrder,Parent=sf})
                cr("UIPadding",{PaddingLeft=UDim.new(0,IPAD),PaddingRight=UDim.new(0,IPAD),PaddingTop=UDim.new(0,PAD),PaddingBottom=UDim.new(0,PAD),Parent=sf})
                W._flatSec = {_frame=sf, _layout=ll}
                if not W._activeSection then
                    W._activeSection = W._flatSec
                end
                table.insert(W.C, ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    _resize()
                end))
            end
            W._flatSec._frame.Position = UDim2.new(0, 0, 0, _secY())
            return W._flatSec._frame
        end
        function W:AddSeparator() _ensureFlat(); return _makeSeparator(W._flatSec._frame) end
        function W:AddLabel(t) _ensureFlat(); return _makeLabel(W._flatSec._frame, t) end
        function W:AddButton(t, c, cn) _ensureFlat(); return _makeButton(W._flatSec._frame, W, t, c, cn) end
        function W:AddToggle(t, st2, c) _ensureFlat(); return _makeToggle(W._flatSec._frame, W, t, st2, c) end
        function W:AddSlider(t, mn2, mx2, df2, stp2, c) _ensureFlat(); return _makeSlider(W._flatSec._frame, W, t, mn2, mx2, df2, stp2, c) end
        function W:AddInput(t, df2, nO2, c) _ensureFlat(); return _makeInput(W._flatSec._frame, W, t, df2, nO2, c) end
        function W:AddCycle(t, arr2, c) _ensureFlat(); return _makeCycle(W._flatSec._frame, W, t, arr2, c) end
        function W:AddKeybind(t, dK2, c) _ensureFlat()
            local kb = _makeKeybind(W._flatSec._frame, W, t, dK2, c)
            table.insert(W._keybinds, kb)
            return kb
        end
        function W:AddDropdown(t, opts, di, c) _ensureFlat(); return _makeDropdown(W._flatSec._frame, W, t, opts, di, c) end
