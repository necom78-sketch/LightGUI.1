		local conn = btn.MouseButton1Click:Connect(function()
			hideContextMenu()
			if item[2] then
				safeCall(item[2])
			end
		end)
		table.insert(ContextMenu._connections, conn)
		local enterConn = btn.MouseEnter:Connect(function()
			btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
		end)
		local leaveConn = btn.MouseLeave:Connect(function()
			btn.BackgroundColor3 = Color3.fromRGB(35,35,35)
		end)
		table.insert(ContextMenu._connections, enterConn)
		table.insert(ContextMenu._connections, leaveConn)
	end
	ContextMenu._outsideConn = UIS.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
