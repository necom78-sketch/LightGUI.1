                    for _, cp in ipairs(W._colorpickers) do
                        if cp.Close then cp:Close() end
                    end
                end
                if W._keybinds then
                    for _, kb in ipairs(W._keybinds) do
                        if kb.CancelWait then kb:CancelWait() end
                    end
