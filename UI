local function makeSlider(parent, window, text, min, max, default, step, callback, textSize)
	if window._destroyed or not parent or not parent.Parent then return end
	assert(min < max, "Slider: min must be < max")
	local theme = window.T
	textSize = textSize or 12
	local value = math.clamp(tonumber(default) or min, min, max)
	step = step or 1
	local container = create("Frame", { Size = UDim2.new(1, 0, 0, theme.BH + 18), BackgroundTransparency = 1, Parent = parent })
	if not container then return end
	local label = create("TextLabel", { Size = UDim2.new(1, 0, 0, 16), BackgroundTransparency = 1, Text = text, TextColor3 = theme.Dim, Font = theme.Fnt, TextSize = textSize, TextXAlignment = Enum.TextXAlignment.Left, Parent = container })
	local track = create("Frame", { Size = UDim2.new(1, -50, 0, 6), Position = UDim2.new(0, 0, 0, 18), BackgroundColor3 = theme.Btn, BorderSizePixel = 0, Parent = container })
	create("UICorner", { CornerRadius = UDim.new(0, 3), Parent = track })
	local fill = create("Frame", { Size = UDim2.new(math.clamp((value - min) / (max - min), 0, 1), 0, 1, 0), BackgroundColor3 = theme.Acc, BorderSizePixel = 0, Parent = track })
	create("UICorner", { CornerRadius = UDim.new(0, 3), Parent = fill })
	local valueLabel = create("TextLabel", { Size = UDim2.new(0, 50, 0, theme.BH), Position = UDim2.new(1, -50, 0, 16), BackgroundTransparency = 1, Text = string.format("%.2f", value), TextColor3 = theme.Txt, Font = theme.Fnt, TextSize = textSize, TextXAlignment = Enum.TextXAlignment.Right, Parent = container })
	local obj = setmetatable({
		min = min, max = max, step = step,
		dragging = false, lastFire = 0, inputType = nil,
		absX = 0, absW = 0,
		_onInputChanged = nil, _onInputEnded = nil
	}, ControlMT)
	function obj:_updateValue(newVal, fireCallback)
		value = newVal
		fill.Size = UDim2.new(math.clamp((value - min) / (max - min), 0, 1), 0, 1, 0)
		valueLabel.Text = string.format("%.2f", value)
		if fireCallback then
			local n = now()
			if n - self.lastFire > 0.05 then
				self.lastFire = n
				safeCallSync(callback, value)
			end
		end
	end
	managedConnect(window, track.InputBegan, function(input)
		if window._destroyed or obj.dragging then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			obj.dragging = true
			obj.inputType = input.UserInputType
			local abs = track.AbsolutePosition
			obj.absX, obj.absW = abs.X, track.AbsoluteSize.X
			local raw = min + (max - min) * math.clamp((input.Position.X - obj.absX) / obj.absW, 0, 1)
			local val = math.floor((raw / step) + 0.5) * step
			val = math.clamp(val, min, max)
			obj:_updateValue(val, true)
			window._activeSlider = obj
		end
	end)
	function obj:_onInputChanged(input)
		if not self.dragging then return end
		if input.UserInputType == self.inputType then
			local raw = min + (max - min) * math.clamp((input.Position.X - self.absX) / self.absW, 0, 1)
			local val = math.floor((raw / step) + 0.5) * step
			val = math.clamp(val, min, max)
			self:_updateValue(val, true)
		end
	end
	function obj:_onInputEnded(input)
		if input.UserInputType == obj.inputType then
			obj.dragging = false
			window._activeSlider = nil
		end
	end
	function obj:Set(newVal, silent)
		if window._destroyed or not track.Parent then return end
		if self.dragging then self.dragging = false; window._activeSlider = nil end
		value = math.clamp(tonumber(newVal) or min, min, max)
		self:_updateValue(value, not silent)
	end
	function obj:Get() return value end
	function obj:Destroy()
		if self.dragging then self.dragging = false; window._activeSlider = nil end
		if obj._cfgEntry then
			for i, e in ipairs(window._cF) do if e == obj._cfgEntry then table.remove(window._cF, i); break end end
			obj._cfgEntry = nil
		end
		if container then container:Destroy() end
	end
	obj._frame = container
	obj.SetEnabled = function(self, enabled)
		if not container then return end
		container.Active = enabled
		label.TextColor3 = enabled and theme.Dim or theme.Dim
		track.Active = enabled
		track.BackgroundTransparency = enabled and 0 or 0.5
		fill.BackgroundColor3 = enabled and theme.Acc or theme.Dim
		valueLabel.TextColor3 = enabled and theme.Txt or theme.Dim
	end
	obj.SetTooltip = function(self, tipText)
		managedConnect(window, container.MouseEnter, function() startTooltip(tipText, container) end)
		managedConnect(window, container.MouseLeave, function() stopTooltip(container) end)
	end
	obj.SetContextMenu = function(self, items) setContextMenu(self, items) end
	obj.set = function(self, th)
		label.TextColor3 = th.Dim
		valueLabel.TextColor3 = th.Txt
		label.Font = th.Fnt
		valueLabel.Font = th.Fnt
		track.BackgroundColor3 = th.Btn
		fill.BackgroundColor3 = th.Acc
	end
	registerConfigField(window, obj, "slider", "slider")
	return obj
end
