            table.clear(optBtns)
            for i, v in ipairs(a) do
                local ob = cr("TextButton",{Size=UDim2.new(1,0,0,20),BackgroundColor3=T.Bg,TextColor3=(i==idx) and T.Acc or T.Txt,Font=T.Fnt,TextSize=12,Text="  "..tostring(v),TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,ZIndex=101,TextTruncate=Enum.TextTruncate.AtEnd,Parent=listF})
                cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=ob})
                table.insert(optBtns, ob)
                local conn = ob.MouseButton1Click:Connect(function()
                    idx = i; btn.Text = tostring(a[idx])
                    for j, ob2 in ipairs(optBtns) do ob2.TextColor3 = (j==idx) and T.Acc or T.Txt end
                    isOpen = false; listF.Visible = false
                    if closeTimer then task.cancel(closeTimer); closeTimer = nil end
                    ss(cb, a[idx])
