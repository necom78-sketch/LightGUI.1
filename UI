        table.insert(W.C, tg.MouseButton1Click:Connect(function()
            minimized = not minimized
            tg.Text = minimized and "+" or "-"
            if minimized then
                mf.Size = UDim2.new(0, WIN_W, 0, TOP_H)
                for _, s2 in ipairs(W._sections) do s2._frame.Visible = false end
                tabRow.Visible = false
                if W._flatSec then W._flatSec._frame.Visible = false end
                if W._dropdowns then
                    for _, dd in ipairs(W._dropdowns) do
                        if dd.Close then dd:Close() end
                    end
                end
