        function o:Set(val, sl)
            local sv = tostring(val)
            for i=1,#a do if tostring(a[i])==sv then idx=i; btn.Text=tostring(a[idx]); if not sl then ss(cb,a[idx]) end; return end end
        end
        function o:SetOptions(newTbl)
            a = table.clone(newTbl or {})
            idx = math.clamp(idx, 1, math.max(1, #a))
            btn.Text = #a > 0 and tostring(a[idx]) or ""
            buildList()
        end
        function o:Close() close() end
        if not W._dropdowns then W._dropdowns = {} end
        table.insert(W._dropdowns, o)
        table.insert(W.C, {Disconnect = function()
            if W._dropdowns then
                local idx2 = _tfind(W._dropdowns, o)
                if idx2 then table.remove(W._dropdowns, idx2) end
            end
        end})
        return o
    end

    local function _makeColorPicker(parent, W, tx, defaultColor, cb)
