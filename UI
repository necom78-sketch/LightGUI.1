local panicKey = nil
local function updateKeybindConnection()
	if next(keybindListeners) == nil and not panicKey then
		if keybindConn then keybindConn:Disconnect(); keybindConn = nil end
	else
		if not keybindConn or not keybindConn.Connected then
			keybindConn = UIS.InputBegan:Connect(function(input, gameProcessed)
				if gameProcessed or input.UserInputType ~= Enum.UserInputType.Keyboard then return end
				local snapshot = {}
				for k, v in pairs(keybindListeners) do snapshot[k] = v end
				for _, entry in pairs(snapshot) do
					if entry.key and input.KeyCode == entry.key then
						safeCall(entry.callback)
					end
				end
				if panicKey and input.KeyCode == panicKey then
					AzraelUI:Destroy()
				end
			end)
		end
	end
end
