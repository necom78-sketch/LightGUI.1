			elseif etype == "Cycle" then proxy:AddCycle(elem[2], elem[3], elem[4])
			elseif etype == "Keybind" then proxy:AddKeybind(elem[2], elem[3], elem[4])
			elseif etype == "Dropdown" then proxy:AddDropdown(elem[2], elem[3], elem[4], elem[5])
			elseif etype == "MultiDropdown" then proxy:AddMultiDropdown(elem[2], elem[3], elem[4], elem[5])
