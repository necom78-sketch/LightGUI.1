        function W:Destroy()
            if _d then return end; _d = true
            if _wins[title] == W then _wins[title] = nil end
            _dragCbs[inID] = nil
            _dragEndCbs[inID] = nil
            _keybindMap[inID] = nil
            if not next(_dragCbs) then _hasActiveDrags = false end
            if _activeSlider and _activeSlider.fill then
                local cur = _activeSlider.fill
                while cur do
                    if cur == sg then
                        _activeSlider = nil
                        break
                    end
                    cur = cur.Parent
                end
            end
            if W._dropdowns then for _, dd in ipairs(W._dropdowns) do if dd.Close then dd:Close() end end end
            if W._colorpickers then for _, cp in ipairs(W._colorpickers) do if cp.Close then cp:Close() end end end
            if W._keybinds then for _, kb in ipairs(W._keybinds) do if kb.CancelWait then kb:CancelWait() end end end
            for _, c in pairs(W.C) do
