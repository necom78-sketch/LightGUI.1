function AzraelUI:CreateWatermark(text, opts)
	if not safeGui then return end
	if watermarkObj and watermarkObj.Destroy then watermarkObj:Destroy() end
	opts = opts or {}
	local sg = create("ScreenGui", { Name = "AzWatermark", DisplayOrder = 100001, Parent = safeGui })
	local pos = opts.position or "top-right"
	local x, y = 0, 0
	local vps = CAM.ViewportSize
	if pos == "top-left" then x, y = 10, 10
	elseif pos == "top-right" then x, y = vps.X - 200, 10
	elseif pos == "bottom-left" then x, y = 10, vps.Y - 30
	elseif pos == "bottom-right" then x, y = vps.X - 200, vps.Y - 30
	end
	local lbl = create("TextLabel", {
		Size = UDim2.new(0, 0, 0, 20),
		Position = UDim2.new(0, x, 0, y),
		BackgroundTransparency = 0.5,
		BackgroundColor3 = Color3.new(0,0,0),
		Text = text,
		TextColor3 = opts.color or Color3.new(1,1,1),
		Font = Enum.Font.SourceSansBold,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = sg
	})
	local bounds = TS:GetTextSize(text, 14, Enum.Font.SourceSansBold, Vector2.new(500, 20))
	lbl.Size = UDim2.new(0, bounds.X + 16, 0, 20)
	watermarkObj = { Destroy = function() sg:Destroy() end, SetText = function(t) lbl.Text = t; local b = TS:GetTextSize(t, 14, Enum.Font.SourceSansBold, Vector2.new(500, 20)); lbl.Size = UDim2.new(0, b.X + 16, 0, 20) end }
	return watermarkObj
end
