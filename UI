local AzraelUI = {}
local UIS = game:GetService("UserInputService")
local TS  = game:GetService("TextService")
local CG  = (gethui and gethui()) or (typeof(syn)=="table" and syn and syn.protect_gui and game:GetService("CoreGui")) or game:GetService("CoreGui")
pcall(function() CG = gethui and gethui() or game:GetService("CoreGui") end)

local T = {
	Bg  = Color3.fromRGB(18,18,18),
	Top = Color3.fromRGB(25,25,25),
	Btn = Color3.fromRGB(35,35,35),
	Acc = Color3.fromRGB(0,140,0),
	Txt = Color3.fromRGB(255,255,255),
	Err = Color3.fromRGB(220,60,60),
	Dim = Color3.fromRGB(130,130,130),
	Sep = Color3.fromRGB(50,50,50),
	Fnt = Enum.Font.SourceSansBold,
	W   = 190,
	BH  = 24,
}

local _MM = Enum.UserInputType.MouseMovement
local _TC = Enum.UserInputType.Touch
local _MB1 = Enum.UserInputType.MouseButton1
local _KB = Enum.UserInputType.Keyboard

local _wId = 0
local _wins = {}
local _nF = nil
local _nfItems = {} -- notification tracking for max queue

-- Module-level slider drag state (consolidated: only one slider drags at a time)
local _activeSlider = nil -- {sD, sDi, lF, ax, aw, mn, mx, stp, fmt, fill, vl, cb, tr}

-- Module-level drag state per window
local _dragCbs = {} -- [id] = function(input)
local _sliderInpCbs = {} -- [id] = function(input) -- for slider drag updates

local function _mob() return UIS.TouchEnabled and not UIS.KeyboardEnabled end
local function ss(f,...) if not f then return end local a={...} task.spawn(function() local ok,e=pcall(f,unpack(a)) if not ok then warn("[AzUI] "..tostring(e)) end end) end
local function cr(c,p) local i=Instance.new(c) for k,v in pairs(p) do if k~="Parent" then i[k]=v end end if p.Parent then i.Parent=p.Parent end return i end

-- Module-level InputChanged (mouse/touch move)
local _icc = UIS.InputChanged:Connect(function(i)
	local t = i.UserInputType
	if t == _MM or t == _TC then
		for _,f in pairs(_dragCbs) do f(i) end
		-- Slider drag update
		if _activeSlider and _activeSlider.sD and i == _activeSlider.sDi then
			local s = _activeSlider
			local nw = os.clock()
			if nw - s.lF > 0.05 then
				s.lF = nw
				local raw = s.mn + (s.mx - s.mn) * math.clamp((i.Position.X - s.ax) / s.aw, 0, 1)
				local sv = string.format(s.fmt, math.floor((raw / s.stp) + 0.5) * s.stp)
				local fv = tonumber(sv) or s.mn
				s.fill.Size = UDim2.new(math.clamp((fv - s.mn) / (s.mx - s.mn), 0, 1), 0, 1, 0)
				s.vl.Text = sv
				ss(s.cb, fv)
			end
		end
	end
end)

-- Module-level InputEnded (mouse/touch release) — handles slider release + window drag end
local _dragEndCbs = {} -- [id] = function(i)
local _iec = UIS.InputEnded:Connect(function(i)
	local t = i.UserInputType
	if t == _MB1 or t == _TC then
		for _, f in pairs(_dragEndCbs) do f(i) end
		-- Slider release
		if _activeSlider and _activeSlider.sD and i == _activeSlider.sDi then
			local s = _activeSlider
			s.sD = false
			s.sDi = nil
			local fv = tonumber(s.vl.Text) or s.mn
			local nw = os.clock()
			if nw - s.lF > 0.05 then ss(s.cb, fv) end
			_activeSlider = nil
		end
	end
end)

-- Module-level keybind handler for W:SetKeybind
local _keybindMap = {} -- [windowId] = {key=Enum.KeyCode, cb=function}
local _keybindConn = UIS.InputBegan:Connect(function(i, gpe)
	if gpe or i.UserInputType ~= _KB then return end
	for _, entry in pairs(_keybindMap) do
		if entry.key and i.KeyCode == entry.key then
			ss(entry.cb)
		end
	end
end)

function AzraelUI:Destroy()
	for _,w in pairs(table.clone(_wins)) do w:Destroy() end
	if _icc then _icc:Disconnect() end
	if _iec then _iec:Disconnect() end
	if _keybindConn then _keybindConn:Disconnect() end
end

function AzraelUI:GetWindow(t) return _wins[t] end

function AzraelUI:Notify(tx, dr, typ)
	if not _nF or not _nF.Parent then
		local sg = cr("ScreenGui",{Name="AzNtf",DisplayOrder=99999,Parent=CG})
		_nF = cr("Frame",{Size=UDim2.new(0,200,1,0),Position=UDim2.new(1,-210,0,0),BackgroundTransparency=1,Parent=sg})
		cr("UIListLayout",{Padding=UDim.new(0,4),VerticalAlignment=Enum.VerticalAlignment.Bottom,SortOrder=Enum.SortOrder.LayoutOrder,Parent=_nF})
		cr("UIPadding",{PaddingBottom=UDim.new(0,16),Parent=_nF})
		_nfItems = {}
	end
	-- Max queue of 5
	while #_nfItems >= 5 do
		local oldest = table.remove(_nfItems, 1)
		if oldest and oldest.Parent then oldest:Destroy() end
	end
	local f = cr("Frame",{Size=UDim2.new(1,0,0,0),BackgroundColor3=T.Bg,ClipsDescendants=true,Parent=_nF})
	cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
	local bC = (typ=="err" and T.Err) or (typ=="ok" and T.Acc) or Color3.fromRGB(0,140,255)
	cr("Frame",{Size=UDim2.new(0,3,1,0),BackgroundColor3=bC,BorderSizePixel=0,Parent=f})
	local l = cr("TextLabel",{Size=UDim2.new(1,-15,0,0),Position=UDim2.new(0,10,0,4),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=13,TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
	local b = TS:GetTextSize(tx,13,T.Fnt,Vector2.new(175,9999))
	l.Size = UDim2.new(1,-15,0,b.Y)
	f.Size = UDim2.new(1,0,0,b.Y+8)
	table.insert(_nfItems, f)
	task.delay(dr or 3, function()
		if f.Parent then
			f:Destroy()
			local idx = table.find(_nfItems, f)
			if idx then table.remove(_nfItems, idx) end
		end
	end)
end

