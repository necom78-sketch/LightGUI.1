local function setContextMenu(element, items)
	if not element._frame then return end
	local guiObj = element._frame
	managedConnect(element.W, guiObj.MouseButton2Click or guiObj.MouseButton2Down or guiObj.InputBegan, function(input)
		if input and input.UserInputType == Enum.UserInputType.MouseButton2 then
			showContextMenu(items, input.Position)
