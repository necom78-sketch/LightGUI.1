local function randomName()
	if FEATURES.crypt then
		local buf = crypt.generatebytes(6)
		local str
		if type(buffer) == "table" and buffer.tostring then
			str = buffer.tostring(buf)
		else
			return "Az_" .. tostring(math.random(100000, 999999))
		end
		if type(str) == "string" and #str >= 6 then
			local encodeFn = crypt.base64.encode
			if encodeFn then
				local ok, result = pcall(encodeFn, str)
				if ok and type(result) == "string" then return result end
			end
		end
	end
	return "Az_" .. tostring(math.random(100000, 999999))
end
local FIRST_PROPS = { AnchorPoint = true }
local LATE_PROPS = { Rotation = true, ZIndex = true, LayoutOrder = true }
local function create(class, props)
	local ok, inst = pcall(Instance.new, class)
	if not ok then return nil end
	for k, v in pairs(props) do
		if FIRST_PROPS[k] then pcall(function() inst[k] = v end) end
	end
	for k, v in pairs(props) do
		if not FIRST_PROPS[k] and k ~= "Parent" and not LATE_PROPS[k] then
			pcall(function() inst[k] = v end)
		end
	end
	for k, v in pairs(props) do
		if LATE_PROPS[k] then pcall(function() inst[k] = v end) end
	end
	if props.Parent then pcall(function() inst.Parent = props.Parent end) end
	return inst
end
local ConnectionManager = {}
ConnectionManager.__index = ConnectionManager
function ConnectionManager.new()
	return setmetatable({ connections = {} }, ConnectionManager)
end
function ConnectionManager:Add(conn)
	if conn and not self.connections[conn] then
		self.connections[conn] = true
	end
end
function ConnectionManager:Remove(conn)
	if conn then self.connections[conn] = nil end
end
function ConnectionManager:Disconnect(conn)
	if conn then
		self.connections[conn] = nil
		pcall(function()
			if type(conn) == "table" and conn.Disconnect then
				conn:Disconnect()
			else
				conn:Disconnect()
			end
		end)
	end
end
function ConnectionManager:Destroy()
	for conn in pairs(self.connections) do
		self:Disconnect(conn)
	end
	tableClear(self.connections)
end
local function managedConnect(self, event, func)
	local conn = event:Connect(func)
	self._connMgr:Add(conn)
	return conn
end
local safeGui
do
	if FEATURES.gethui then
		local ok, result = pcall(gethui)
		if ok and result and result.Parent then
			safeGui = result
		end
	end
	if not safeGui then
		local coreGui = getServiceSafe("CoreGui")
		if coreGui then
			local sg = Instance.new("ScreenGui")
			sg.Name = randomName()
			sg.ResetOnSpawn = false
			sg.DisplayOrder = 99999
			if pcall(function() sg.Parent = coreGui end) and sg.Parent then
				safeGui = sg
			else
				sg:Destroy()
			end
		end
	end
	if not safeGui then
		local players = getServiceSafe("Players")
		local lp = players and players.LocalPlayer
		if lp then
			local playerGui = lp:FindFirstChildOfClass("PlayerGui")
			if playerGui then
				local sg = Instance.new("ScreenGui")
				sg.Name = randomName()
				sg.ResetOnSpawn = false
				sg.DisplayOrder = 99999
				pcall(function() sg.Parent = playerGui end)
				if sg.Parent then safeGui = sg else sg:Destroy() end
			end
		end
	end
	if not safeGui then
		local sg = Instance.new("ScreenGui")
		sg.Name = randomName()
		sg.DisplayOrder = 99999
		pcall(function() sg.Parent = game end)
		if sg.Parent then safeGui = sg else sg:Destroy() end
	end
end
