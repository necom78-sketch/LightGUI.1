local AzraelUI
do
    AzraelUI = {}
    local UIS = game:GetService("UserInputService")
    local TS = game:GetService("TextService")
    local CAM = game:GetService("Workspace").CurrentCamera

    local CG
    do
        if typeof(gethui) == "function" then
            local ok, r = pcall(gethui)
            if ok and r then CG = r end
        end
        if not CG and typeof(syn) == "table" and syn and typeof(syn.protect_gui) == "function" then
            local ok, r = pcall(function() return game:GetService("CoreGui") end)
            if ok and r then CG = r end
        end
        if not CG then
            local ok, r = pcall(function() return game:GetService("CoreGui") end)
            if ok and r then CG = r end
        end
        if not CG then
            pcall(function() CG = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui") end)
        end
        if not CG then
            local fallback = Instance.new("ScreenGui")
            fallback.Name = "AzFallback_" .. tostring(math.random(10000,99999))
            fallback.Parent = game:GetService("CoreGui")
            CG = fallback
        end
    end

    local T = {
        Bg  = Color3.fromRGB(18,18,18),
        Top = Color3.fromRGB(25,25,25),
        Btn = Color3.fromRGB(35,35,35),
        Acc = Color3.fromRGB(0,140,0),
        Txt = Color3.fromRGB(255,255,255),
        Err = Color3.fromRGB(220,60,60),
        Dim = Color3.fromRGB(130,130,130),
        Sep = Color3.fromRGB(50,50,50),
        Fnt = Enum.Font.SourceSansBold,
        W   = 190,
        BH  = 24,
    }
    local _MM  = Enum.UserInputType.MouseMovement
    local _TC  = Enum.UserInputType.Touch
    local _MB1 = Enum.UserInputType.MouseButton1
    local _KB  = Enum.UserInputType.Keyboard

    local _wId = 0
    local _wins = {}
    local _nF = nil
    local _nfItems = {}

    local _dragCbs, _dragEndCbs = {}, {}
    local _hasActiveDrags = false
    local _inputBeganCbs = {}

    local _activeSlider = nil

    local function _tfind(t, v)
        for i = 1, #t do if t[i] == v then return i end end
        return nil
    end

    local function _mob() return UIS.TouchEnabled and not UIS.KeyboardEnabled end

    local function _randomName()
        if crypt and crypt.generatebytes then
            return crypt.generatebytes(8)
        else
            return "Az_" .. tostring(math.random(100000,999999))
        end
    end

    local function ss(f, ...)
        if not f then return end
        if newcclosure and not iscclosure(f) then
            f = newcclosure(f)
        end
        task.spawn(function(...) pcall(f, ...) end, ...)
    end

    local _CR_LATE_PROPS = {TextInputType = true, Rotation = true}
    local function cr(c, p)
        local i = Instance.new(c)
        for k, v in pairs(p) do
            if k ~= "Parent" and not _CR_LATE_PROPS[k] then i[k] = v end
        end
        for k, v in pairs(p) do
            if _CR_LATE_PROPS[k] then i[k] = v end
        end
        if p.Parent then i.Parent = p.Parent end
        return i
    end

    local _icc, _iec, _keybindConn, _inputBeganConn
    local function _ensureModuleConns()
        if not _icc or not _icc.Connected then
            _icc = UIS.InputChanged:Connect(function(i)
                local t = i.UserInputType
                if t == _MM or t == _TC then
                    if _activeSlider and _activeSlider.sD then
                        local s = _activeSlider
                        if s.fill and s.fill.Parent and s.tr and s.tr.Parent then
                            if t == s.inputType then
                                local raw = s.mn + (s.mx - s.mn) * math.clamp((i.Position.X - s.ax) / s.aw, 0, 1)
                                local sv = string.format(s.fmt, math.floor((raw / s.stp) + 0.5) * s.stp)
                                local fv = tonumber(sv) or s.mn
                                s.fill.Size = UDim2.new(math.clamp((fv - s.mn) / (s.mx - s.mn), 0, 1), 0, 1, 0)
                                s.vl.Text = sv
                                s.lastPos = i.Position.X
                                local nw = os.clock()
                                if nw - s.lF > 0.05 then
                                    s.lF = nw
                                    ss(s.cb, fv)
                                end
                            end
                        else
                            _activeSlider = nil
                        end
                    end
                    if _hasActiveDrags then
                        for _, f in pairs(_dragCbs) do f(i) end
                    end
                end
            end)
        end
        if not _iec or not _iec.Connected then
            _iec = UIS.InputEnded:Connect(function(i)
                local t = i.UserInputType
                if t == _MB1 or t == _TC then
                    if _activeSlider and _activeSlider.sD and t == _activeSlider.inputType then
                        local s = _activeSlider
                        if s.fill and s.fill.Parent then
                            s.sD = false
                            local posX = s.lastPos or i.Position.X
                            local raw = s.mn + (s.mx - s.mn) * math.clamp((posX - s.ax) / s.aw, 0, 1)
                            local sv = string.format(s.fmt, math.floor((raw / s.stp) + 0.5) * s.stp)
                            local fv = tonumber(sv) or s.mn
                            s.fill.Size = UDim2.new(math.clamp((fv - s.mn) / (s.mx - s.mn), 0, 1), 0, 1, 0)
                            s.vl.Text = sv
                            ss(s.cb, fv)
                        end
                        _activeSlider = nil
                    end
                    if _hasActiveDrags then
                        for _, f in pairs(_dragEndCbs) do f(i) end
                    end
                end
            end)
        end
        if not _keybindConn or not _keybindConn.Connected then
            _keybindConn = UIS.InputBegan:Connect(function(i, gpe)
                if gpe or i.UserInputType ~= _KB then return end
                for _, entry in pairs(_keybindMap) do
                    if entry.key and i.KeyCode == entry.key then ss(entry.cb) end
                end
            end)
        end
        if not _inputBeganConn or not _inputBeganConn.Connected then
            _inputBeganConn = UIS.InputBegan:Connect(function(i)
                if i.UserInputType == _MB1 or i.UserInputType == _TC then
                    for _, f in pairs(_inputBeganCbs) do f(i) end
                end
            end)
        end
    end

    local _keybindMap = {}

    _ensureModuleConns()

    function AzraelUI:Destroy()
        for _, w in pairs(table.clone(_wins)) do pcall(w.Destroy, w) end
        if next(_wins) == nil then
            if _icc then _icc:Disconnect(); _icc = nil end
            if _iec then _iec:Disconnect(); _iec = nil end
            if _keybindConn then _keybindConn:Disconnect(); _keybindConn = nil end
            if _inputBeganConn then _inputBeganConn:Disconnect(); _inputBeganConn = nil end
            table.clear(_dragCbs)
            table.clear(_dragEndCbs)
            table.clear(_keybindMap)
            table.clear(_inputBeganCbs)
            _hasActiveDrags = false
            _activeSlider = nil
            if _nF and _nF.Parent then _nF.Parent:Destroy() end
            _nF = nil
            _nfItems = {}
        end
    end

    function AzraelUI:GetWindow(t) return _wins[t] end

    function AzraelUI:Notify(tx, dr, typ)
        tx = tostring(tx or "")
        dr = math.max(0.5, tonumber(dr) or 3)
        if not _nF or not _nF.Parent then
            local sg = cr("ScreenGui",{Name=_randomName(),DisplayOrder=99999,Parent=CG})
            _nF = cr("Frame",{Size=UDim2.new(0,200,1,0),Position=UDim2.new(1,-210,0,0),BackgroundTransparency=1,Parent=sg})
            cr("UIListLayout",{Padding=UDim.new(0,4),VerticalAlignment=Enum.VerticalAlignment.Bottom,SortOrder=Enum.SortOrder.LayoutOrder,Parent=_nF})
            cr("UIPadding",{PaddingBottom=UDim.new(0,16),Parent=_nF})
            _nfItems = {}
        end
        while #_nfItems >= 5 do
            local oldest = table.remove(_nfItems, 1)
            if oldest and oldest.Parent then oldest:Destroy() end
        end
        local f = cr("Frame",{Size=UDim2.new(1,0,0,0),BackgroundColor3=T.Bg,ClipsDescendants=true,Parent=_nF})
        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
        local bC = (typ=="err" and T.Err) or (typ=="ok" and T.Acc) or Color3.fromRGB(0,140,255)
        cr("Frame",{Size=UDim2.new(0,3,1,0),BackgroundColor3=bC,BorderSizePixel=0,Parent=f})
        local l = cr("TextLabel",{Size=UDim2.new(1,-15,0,0),Position=UDim2.new(0,10,0,4),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=13,TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
        local b = TS:GetTextSize(tx,13,T.Fnt,Vector2.new(175,9999))
        l.Size = UDim2.new(1,-15,0,b.Y)
        f.Size = UDim2.new(1,0,0,b.Y+8)
        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(0,0,0)
        stroke.Thickness = 0.8
        stroke.Parent = l
        table.insert(_nfItems, f)
        task.delay(dr, function()
            if f and f.Parent then
                f:Destroy()
                local idx = _tfind(_nfItems, f)
                if idx then table.remove(_nfItems, idx) end
            end
        end)
    end

    local function _makeSeparator(parent)
        return cr("Frame",{Size=UDim2.new(1,0,0,1),BackgroundColor3=T.Sep,BorderSizePixel=0,Parent=parent})
    end

    local function _makeLabel(parent, tx)
        return cr("TextLabel",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,Text=tx,TextColor3=T.Dim,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=parent})
    end

    local function _makeButton(parent, W, tx, cb, cnf)
        local b = cr("TextButton",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,Text="  "..tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,TextTruncate=Enum.TextTruncate.AtEnd,Parent=parent})
        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=b})
        local cS = false
        local confirmTimer = nil
        local conn1 = b.InputBegan:Connect(function(i) if (i.UserInputType==_MB1 or i.UserInputType==_TC) and not cS then b.BackgroundTransparency=0.3 end end)
        local conn2 = b.InputEnded:Connect(function(i) if i.UserInputType==_MB1 or i.UserInputType==_TC then b.BackgroundTransparency=0 end end)
        local conn3 = b.MouseButton1Click:Connect(function()
            if cnf and not cS then
                cS = true; b.Text = "  Подтвердить?"; b.TextColor3 = T.Err
                confirmTimer = task.delay(3, function()
                    if cS and b.Parent then
                        cS = false; b.Text = "  "..tx; b.TextColor3 = T.Txt
                    end
                    confirmTimer = nil
                end)
                return
            end
            if cnf and cS then
                if confirmTimer then task.cancel(confirmTimer); confirmTimer = nil end
            end
            cS = false; b.Text = "  "..tx; b.TextColor3 = T.Txt; ss(cb)
        end)
        table.insert(W.C, conn1); table.insert(W.C, conn2); table.insert(W.C, conn3)
        table.insert(W.C, {Disconnect = function() if confirmTimer then task.cancel(confirmTimer) end end})
        return b
    end

    local function _makeToggle(parent, W, tx, st, cb)
        local v = st == true
        local b = cr("TextButton",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=v and T.Acc or T.Btn,Text="  "..tx..(v and "  ✓" or "  ✗"),TextColor3=T.Txt,Font=T.Fnt,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,TextTruncate=Enum.TextTruncate.AtEnd,Parent=parent})
        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=b})
        local o = {}
        function o:Set(nv, sl) v=nv; b.BackgroundColor3=v and T.Acc or T.Btn; b.Text="  "..tx..(v and "  ✓" or "  ✗"); if not sl then ss(cb,v) end end
        function o:Get() return v end
        table.insert(W.C, b.MouseButton1Click:Connect(function() o:Set(not v) end))
        return o
    end

    local function _nanGuard(x, fb) if x ~= x or x == math.huge or x == -math.huge then return fb end return x end

    local function _makeSlider(parent, W, tx, mn, mx, df, stp, cb)
        mn  = _nanGuard(tonumber(mn) or 0, 0); mx = _nanGuard(tonumber(mx) or 1, 1)
        stp = _nanGuard(tonumber(stp) or 1, 1); if stp <= 0 then stp = 1 end
        if mx <= mn then mx = mn + 1 end
        df = math.clamp(_nanGuard(tonumber(df) or mn, mn), mn, mx)
        local dcs = stp < 1 and math.min(6, math.max(0, math.ceil(-math.log10(stp)))) or 0
        local fmt = "%."..dcs.."f"
        local inW = 38
        local f = cr("Frame",{Size=UDim2.new(1,0,0,38),BackgroundColor3=T.Btn,Parent=parent})
        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
        cr("TextLabel",{Size=UDim2.new(1,-inW-6,0,18),Position=UDim2.new(0,5,0,1),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
        local vl = cr("TextBox",{Size=UDim2.new(0,inW,0,16),Position=UDim2.new(1,-inW-4,0,2),BackgroundColor3=T.Bg,TextColor3=T.Acc,Font=T.Fnt,TextSize=12,Text=string.format(fmt,df),ClearTextOnFocus=false,TextXAlignment=Enum.TextXAlignment.Center,ClipsDescendants=true,Parent=f})
        cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=vl})
        if _mob() then vl.TextInputType = Enum.TextInputType.Number end
        local tr = cr("Frame",{Size=UDim2.new(1,-10,0,4),Position=UDim2.new(0,5,0,26),BackgroundColor3=T.Bg,Parent=f})
        cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=tr})
        local fill = cr("Frame",{Size=UDim2.new(math.clamp((df-mn)/(mx-mn),0,1),0,1,0),BackgroundColor3=T.Acc,Parent=tr})
        cr("UICorner",{CornerRadius=UDim.new(0,2),Parent=fill})
        local hit = cr("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,Parent=tr})
        local o = {}
        function o:Get() return tonumber(vl.Text) or mn end
        function o:Set(nv, sl)
            nv = _nanGuard(tonumber(nv) or mn, mn)
            local sv = string.format(fmt, math.clamp(math.floor((nv/stp)+0.5)*stp, mn, mx))
            local fv = tonumber(sv) or mn
            if fill and fill.Parent then fill.Size = UDim2.new(math.clamp((fv-mn)/(mx-mn),0,1), 0, 1, 0) end
            vl.Text = sv
            if not sl then ss(cb, fv) end
        end
        table.insert(W.C, hit.InputBegan:Connect(function(i)
            if i.UserInputType == _MB1 or i.UserInputType == _TC then
                _ensureModuleConns()
                if not tr or not tr.Parent then return end
                _activeSlider = {
                    sD = true, lF = 0,
                    inputType = i.UserInputType,
                    lastPos = i.Position.X,
                    ax = tr.AbsolutePosition.X, aw = tr.AbsoluteSize.X,
                    mn = mn, mx = mx, stp = stp, fmt = fmt,
                    fill = fill, vl = vl, cb = cb, tr = tr,
                }
                local raw = mn + (mx - mn) * math.clamp((i.Position.X - _activeSlider.ax) / _activeSlider.aw, 0, 1)
                local sv = string.format(fmt, math.floor((raw / stp) + 0.5) * stp)
                local fv = tonumber(sv) or mn
                fill.Size = UDim2.new(math.clamp((fv-mn)/(mx-mn),0,1), 0, 1, 0)
                vl.Text = sv
                ss(cb, fv)
                _activeSlider.lF = os.clock()
            end
        end))
        table.insert(W.C, vl.FocusLost:Connect(function()
            local nv = tonumber(vl.Text)
            if nv and nv == nv and nv ~= math.huge and nv ~= -math.huge then
                o:Set(nv, true); ss(cb, o:Get())
            else
                vl.Text = string.format(fmt, mn)
            end
        end))
        return o
    end

    local function _makeInput(parent, W, tx, df, nO, cb)
        local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,Parent=parent})
        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
        cr("TextLabel",{Size=UDim2.new(0.55,0,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
        local tB = cr("TextBox",{Size=UDim2.new(0.45,-8,1,-6),Position=UDim2.new(0.55,3,0,3),BackgroundColor3=T.Bg,TextColor3=T.Acc,Font=T.Fnt,TextSize=12,Text=tostring(df),ClearTextOnFocus=false,ClipsDescendants=true,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
        if _mob() and nO then tB.TextInputType = Enum.TextInputType.Number end
        cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=tB})
        local lastValid = tostring(df)
        table.insert(W.C, tB.Focused:Connect(function() if nO then tB.Text="" end end))
        table.insert(W.C, tB.FocusLost:Connect(function()
            if nO and not tonumber(tB.Text) then tB.Text=lastValid; return end
            lastValid = tB.Text; ss(cb, tB.Text)
        end))
        local o = {}
        function o:Set(nv, sl) tB.Text=tostring(nv); lastValid=tostring(nv); if not sl then ss(cb,nv) end end
        function o:Get() return tB.Text end
        return o
    end

    local function _makeCycle(parent, W, tx, arr, cb)
        if not arr or #arr == 0 then
            return {Get=function() return nil end, Set=function() end}
        end
        local a = table.clone(arr)
        local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,Parent=parent})
        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
        cr("TextLabel",{Size=UDim2.new(0.5,0,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
        local b = cr("TextButton",{Size=UDim2.new(0.5,-8,1,-6),Position=UDim2.new(0.5,3,0,3),BackgroundColor3=T.Bg,TextColor3=T.Acc,Font=T.Fnt,TextSize=12,Text=tostring(a[1]),AutoButtonColor=false,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
        cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=b})
        local idx = 1
        local o = {}
        function o:Set(val, sl)
            local sv = tostring(val)
            for i=1,#a do if tostring(a[i])==sv then idx=i; b.Text=tostring(a[idx]); if not sl then ss(cb,a[idx]) end; return end end
        end
        function o:Get() return a[idx] end
        table.insert(W.C, b.MouseButton1Click:Connect(function() idx=idx+1; if idx>#a then idx=1 end; b.Text=tostring(a[idx]); ss(cb,a[idx]) end))
        return o
    end

    local function _makeKeybind(parent, W, tx, dK, cb)
        if _mob() then
            return {Get=function() return nil end, Set=function() end, CancelWait=function() end}
        end
        local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,Parent=parent})
        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
        cr("TextLabel",{Size=UDim2.new(0.55,0,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
        local b = cr("TextButton",{Size=UDim2.new(0.45,-8,1,-6),Position=UDim2.new(0.55,3,0,3),BackgroundColor3=T.Bg,TextColor3=T.Dim,Font=T.Fnt,TextSize=12,Text=dK and dK.Name or "None",AutoButtonColor=false,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
        cr("UICorner",{CornerRadius=UDim.new(0,3),Parent=b})
        local k, w = dK, false
        local cancelDelay = nil
        local clickConn
        clickConn = b.MouseButton1Click:Connect(function()
            if w then return end
            w = true; b.Text = "..."
            if cancelDelay then task.cancel(cancelDelay) end
            cancelDelay = task.delay(5, function()
                if w and b.Parent then
                    w = false
                    entry.waiting = false
                    b.Text = k and k.Name or "None"
                end
                cancelDelay = nil
            end)
        end)
        table.insert(W.C, clickConn)
        if not W._kbListening then
            W._kbListening = true
            W._kbWaiters = {}
            local kbConn = UIS.InputBegan:Connect(function(i, g)
                if g or i.UserInputType ~= _KB then return end
                for _, entry in ipairs(W._kbWaiters) do
                    if entry.waiting then entry.handler(i) end
                end
            end)
            table.insert(W.C, kbConn)
        end
        local entry = {waiting = false, handler = nil}
        entry.handler = function(i)
            if not entry.waiting then return end
            entry.waiting = false
            w = false
            if cancelDelay then
                task.cancel(cancelDelay)
                cancelDelay = nil
            end
            if i.KeyCode == Enum.KeyCode.Escape then k=nil; b.Text="None" else k=i.KeyCode; b.Text=k.Name end
            ss(cb, k)
        end
        table.insert(W._kbWaiters, entry)
        local newClickConn = b.MouseButton1Click:Connect(function()
            if w then return end
            w = true; entry.waiting = true; b.Text = "..."
            if cancelDelay then task.cancel(cancelDelay) end
            cancelDelay = task.delay(5, function()
                if w and b.Parent then
                    w = false; entry.waiting = false
                    b.Text = k and k.Name or "None"
                end
                cancelDelay = nil
            end)
        end)
        table.insert(W.C, newClickConn)
        local o = {}
        function o:Set(nk, sl) k=nk; b.Text=nk and nk.Name or "None"; if not sl then ss(cb,k) end end
        function o:Get() return k end
        function o:CancelWait()
            if w then
                w = false; entry.waiting = false
                if cancelDelay then task.cancel(cancelDelay); cancelDelay = nil end
                b.Text = k and k.Name or "None"
            end
        end
        return o
    end

    local function _makeDropdown(parent, W, tx, options, defaultIndex, cb)
        local a = table.clone(options or {})
        local idx = math.clamp(defaultIndex or 1, 1, math.max(1, #a))
        local f = cr("Frame",{Size=UDim2.new(1,0,0,T.BH),BackgroundColor3=T.Btn,ClipsDescendants=false,Parent=parent})
        cr("UICorner",{CornerRadius=UDim.new(0,4),Parent=f})
        cr("TextLabel",{Size=UDim2.new(0.45,0,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text=tx,TextColor3=T.Txt,Font=T.Fnt,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,Parent=f})
