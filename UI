            end
            listF.Size = UDim2.new(1, 0, 0, #a * 21 + 4)
        end
        buildList()
        table.insert(W.C, btn.MouseButton1Click:Connect(function()
            isOpen = not isOpen; listF.Visible = isOpen
            if isOpen then
                if closeTimer then task.cancel(closeTimer) end
