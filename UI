function AzraelUI:Notify(text, duration, type, customColor)
	if not safeGui then return end
	text = tostring(text or "")
	duration = math.max(0, tonumber(duration) or 3)
	if duration == 0 then return end
	if not notificationFrame or not notificationFrame.Parent then
		local sg = create("ScreenGui", { Name = randomName(), DisplayOrder = 99999, Parent = safeGui })
		if not sg then return end
		notificationFrame = create("Frame", {
			Size = UDim2.new(0, 200, 1, 0),
			Position = UDim2.new(1, -210, 0, 0),
			BackgroundTransparency = 1,
			Parent = sg
		})
		if not notificationFrame then return end
		create("UIListLayout", {
			Padding = UDim.new(0, 4),
			VerticalAlignment = Enum.VerticalAlignment.Bottom,
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = notificationFrame
		})
		create("UIPadding", { PaddingBottom = UDim.new(0, 16), Parent = notificationFrame })
		if notificationItems then
			for _, item in ipairs(notificationItems) do
				if item and item.Parent then item:Destroy() end
			end
			tableClear(notificationItems)
		else
			notificationItems = {}
		end
	end
	while #notificationItems >= 5 do
		local oldest = table.remove(notificationItems, 1)
		if oldest and oldest.Parent then oldest:Destroy() end
	end
	local frame = create("Frame", {
		Size = UDim2.new(1, 0, 0, 0),
		BackgroundColor3 = DefaultTheme.Bg,
		ClipsDescendants = true,
		Parent = notificationFrame
	})
	if not frame then return end
	create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = frame })
	local barColor = customColor
		or (type == "err" and DefaultTheme.Err)
		or (type == "ok" and DefaultTheme.Acc)
		or Color3.fromRGB(0,140,255)
	create("Frame", {
		Size = UDim2.new(0, 3, 1, 0),
		BackgroundColor3 = barColor,
		BorderSizePixel = 0,
		Parent = frame
	})
	local label = create("TextLabel", {
		Size = UDim2.new(1, -15, 0, 0),
		Position = UDim2.new(0, 10, 0, 4),
		BackgroundTransparency = 1,
		Text = text,
		TextColor3 = DefaultTheme.Txt,
		Font = DefaultTheme.Fnt,
		TextSize = 13,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate = Enum.TextTruncate.AtEnd,
		Parent = frame
	})
	if label then
		local textBounds = TS:GetTextSize(text, 13, DefaultTheme.Fnt, Vector2.new(175, 9999))
		label.Size = UDim2.new(1, -15, 0, textBounds.Y)
		frame.Size = UDim2.new(1, 0, 0, textBounds.Y + 8)
		local ok, stroke = pcall(Instance.new, "UIStroke")
		if ok and stroke then
			stroke.Color = Color3.new(0,0,0)
			stroke.Thickness = 0.8
			stroke.Parent = label
		end
	end
	table.insert(notificationItems, frame)
	local closed = false
	local timer
	local function closeNotify()
		if closed then return end
		closed = true
		cancelTimer(timer)
		if timer and notificationTimers[timer] then
			notificationTimers[timer] = nil
		end
		if frame and frame.Parent then frame:Destroy() end
		for i, v in ipairs(notificationItems) do
			if v == frame then table.remove(notificationItems, i); break end
		end
	end
	timer = taskDelay(duration, closeNotify)
	notificationTimers[timer] = true
	return { Close = closeNotify }
end
