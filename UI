                local mp = i.Position
                local ap = listF.AbsolutePosition
                local as = listF.AbsoluteSize
                local bp = btn.AbsolutePosition
                local bs = btn.AbsoluteSize
                local inList = mp.X >= ap.X and mp.X <= ap.X+as.X and mp.Y >= ap.Y and mp.Y <= ap.Y+as.Y
                local inBtn = mp.X >= bp.X and mp.X <= bp.X+bs.X and mp.Y >= bp.Y and mp.Y <= bp.Y+bs.Y
                if not inList and not inBtn then isOpen=false; listF.Visible=false end
