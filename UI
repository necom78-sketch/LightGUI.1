local function now()
	local ok, val = pcall(os.clock)
	if ok then return val end
	ok, val = pcall(tick)
	if ok then return val end
	return 0
end
local tableClear = table.clear or function(t)
	for k in pairs(t) do t[k] = nil end
end
local spawnFn = type(spawn) == "function" and spawn or function(f)
	coroutine.wrap(function() pcall(f) end)()
end
local waitGlobal = type(wait) == "function" and wait or nil
local function busyWait(t)
	local start = now()
	while now() - start < t do end
end
local taskWait = type(task) == "table" and type(task.wait) == "function" and task.wait or waitGlobal or busyWait
local taskSpawn = type(task) == "table" and type(task.spawn) == "function" and task.spawn or spawnFn
local taskDefer = type(task) == "table" and type(task.defer) == "function" and task.defer or taskSpawn
local taskDelay = type(task) == "table" and type(task.delay) == "function" and task.delay or (type(delay) == "function" and delay) or function(t, f)
	local cancelled = false
	spawnFn(function()
		taskWait(t)
		if not cancelled then f() end
	end)
	return { Cancel = function() cancelled = true end }
end
local taskCancel = type(task) == "table" and type(task.cancel) == "function" and task.cancel or function(timer)
	if type(timer) == "table" and timer.Cancel then
		pcall(timer.Cancel, timer)
	end
end
local function cancelTimer(timer)
	if not timer then return end
	local ok = pcall(taskCancel, timer)
	if not ok and type(timer) == "table" and timer.Cancel then
		pcall(timer.Cancel, timer)
	end
end
local function safeCall(f, ...)
	if not f then return end
	taskSpawn(function(...) pcall(f, ...) end, ...)
end
local function safeCallSync(f, ...)
	if not f then return end
	pcall(f, ...)
end
local function isEnumItem(val)
